{
  "entities": {
    "User": {
      "title": "User",
      "description": "Stores user data, coin balance, and free trial status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "coins": { "type": "number" },
        "freeTrialUsed": { "type": "boolean" },
        "lastUsed": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "coins"]
    },
    "Key": {
      "title": "Security Key",
      "description": "Keys generated by admin to grant coins to users.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "userName": { "type": "string" },
        "coins": { "type": "number" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "userName", "coins"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global settings for the admin panel.",
      "type": "object",
      "properties": {
        "adminPassword": { "type": "string" }
      },
      "required": ["adminPassword"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and coin balances."
    },
    "/keys/{keyId}": {
      "schema": "Key",
      "description": "Security keys for adding coins."
    },
    "/settings/admin": {
      "schema": "AdminSettings",
      "description": "Admin configuration."
    }
  }
}

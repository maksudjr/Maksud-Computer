rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Workaround: If Anonymous Auth is disabled in the console, 
      // we allow operations without auth for now to keep the app functional.
      // In a real production app, Anonymous Auth or another provider MUST be enabled.
      return true;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /keys/{keyId} {
      // Allow anyone to read a key if they know the code (checked via query)
      allow read: if true;
      
      // Allow anyone to update a key (for coin deduction)
      allow update: if request.resource.data.code == resource.data.code &&
                      request.resource.data.userName == resource.data.userName;
      
      // Allow admin to create/delete any key
      // Allow public to create ONLY "Free Access" keys with strict limits
      allow create: if isAdmin() || (
        request.resource.data.isFreeAccess == true &&
        request.resource.data.coins == 1 &&
        request.resource.data.userName == "Free Guest" &&
        request.resource.data.freeTrialUsed == true
      );
      
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /paymentRequests/{requestId} {
      allow create: if true; // Anyone can submit a payment request
      allow read, delete: if isAdmin();
    }
  }
}

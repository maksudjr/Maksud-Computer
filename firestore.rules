rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Reverted to allow anonymous auth for admin actions as requested.
      // In a production app, you should use a more secure method like custom claims.
      return isAuthenticated();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /keys/{keyId} {
      // Allow anyone to read a key if they know the code (checked via query)
      allow read: if true;
      
      // Allow anyone to update a key (for coin deduction)
      allow update: if request.resource.data.code == resource.data.code &&
                      request.resource.data.userName == resource.data.userName;
      
      // Allow admin to create/delete any key
      // Allow public to create ONLY "Free Access" keys with strict limits
      allow create: if isAdmin() || (
        request.resource.data.isFreeAccess == true &&
        request.resource.data.coins == 1 &&
        request.resource.data.userName == "Free Guest" &&
        request.resource.data.freeTrialUsed == true
      );
      
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
